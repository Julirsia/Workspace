class Filter:
    class Valves(BaseModel):
        priority: int = Field(default=0)
        inject_depth_hint: bool = Field(
            default=False,
            description="Inject a prompt nudge that matches the chosen depth level.",
        )
        default_thinking_depth: Literal[
            "Unlimited", "MAX", "Deep", "Normal", "Quick"
        ] = Field(default="Unlimited", description=DEPTH_DESC)
        default_thinking_preset: Literal[
            "None",
            "Think Less",
            "Think More",
            "Extended Thinking",
            "MAX Thinking",
            "Step by Step",
            "Devil's Advocate",
            "First Principles",
            "10x Hypotheses",
            "Socratic",
            "Rubber Duck",
            "Pre-Mortem",
            "Bayesian",
            "Contrarian",
        ] = Field(default="None", description=THINKING_DESC)
        default_presentation_preset: Literal[
            "None",
            "ELI5",
            "Be Concise",
            "Bullet Points",
            "TL;DR First",
            "Teach Me",
            "Expert Tone",
            "Casual Chat",
            "Debate Format",
            "Analogies Only",
            "Action Items",
            "Socratic Reply",
        ] = Field(default="None", description=PRESENTATION_DESC)

    class UserValves(BaseModel):
        thinking_depth: Literal["Unlimited", "MAX", "Deep", "Normal", "Quick"] = Field(
            default="Unlimited", description=DEPTH_DESC
        )
        thinking_preset: Literal[
            "None",
            "Think Less",
            "Think More",
            "Extended Thinking",
            "MAX Thinking",
            "Step by Step",
            "Devil's Advocate",
            "First Principles",
            "10x Hypotheses",
            "Socratic",
            "Rubber Duck",
            "Pre-Mortem",
            "Bayesian",
            "Contrarian",
        ] = Field(default="None", description=THINKING_DESC)
        presentation_preset: Literal[
            "None",
            "ELI5",
            "Be Concise",
            "Bullet Points",
            "TL;DR First",
            "Teach Me",
            "Expert Tone",
            "Casual Chat",
            "Debate Format",
            "Analogies Only",
            "Action Items",
            "Socratic Reply",
        ] = Field(default="None", description=PRESENTATION_DESC)

    def __init__(self):
        self.valves = self.Valves()
        self.toggle = True
        self.icon = "data:image/svg+xml;base64,"

    def inlet(self, body: dict, __user__: Optional[dict] = None) -> dict:

        # ── 1. Resolve depth (user > admin) ───────────────────────────────────
        depth = self.valves.default_thinking_depth
        if __user__ and "valves" in __user__:
            try:
                user_depth = __user__["valves"].thinking_depth
                if user_depth != "Unlimited" or depth == "Unlimited":
                    depth = user_depth
            except Exception:
                pass

        # ── 2. Resolve thinking preset (user > admin) ─────────────────────────
        thinking_key = self.valves.default_thinking_preset
        if __user__ and "valves" in __user__:
            try:
                user_thinking = __user__["valves"].thinking_preset
                if user_thinking != "None":
                    thinking_key = user_thinking
            except Exception:
                pass

        # ── 3. Resolve presentation preset (user > admin) ────────────────────
        presentation_key = self.valves.default_presentation_preset
        if __user__ and "valves" in __user__:
            try:
                user_presentation = __user__["valves"].presentation_preset
                if user_presentation != "None":
                    presentation_key = user_presentation
            except Exception:
                pass

        # ── 4. Inject llama.cpp thinking params ───────────────────────────────
        body["chat_template_kwargs"] = {"enable_thinking": True}
        body["reasoning_budget"] = DEPTH_MAP.get(depth, -1)

        # ── 5. Build injection text ───────────────────────────────────────────
        parts = []
        if self.valves.inject_depth_hint:
            hint = DEPTH_HINTS.get(depth, "")
            if hint:
                parts.append(hint)
        thinking_text = THINKING_PRESETS.get(thinking_key, "")
        if thinking_text:
            parts.append(thinking_text)
        presentation_text = PRESENTATION_PRESETS.get(presentation_key, "")
        if presentation_text:
            parts.append(presentation_text)

        if not parts:
            return body

        injection = "\n\n".join(parts)
        messages = body.get("messages", [])

        # ── 6. Inject into system message ─────────────────────────────────────
        sys_idx = next(
            (i for i, m in enumerate(messages) if m.get("role") == "system"), None
        )
        if sys_idx is not None:
            existing = messages[sys_idx].get("content", "")
            messages[sys_idx]["content"] = (
                f"{injection}\n\n{existing}" if existing else injection
            )
        else:
            messages.insert(0, {"role": "system", "content": injection})

        # ── 7. Hard fallback: stamp last user message ─────────────────────────
        for i in range(len(messages) - 1, -1, -1):
            if messages[i].get("role") == "user":
                content = messages[i].get("content", "")
                if isinstance(content, list):
                    content.append(
                        {"type": "text", "text": f"\n[System instruction: {injection}]"}
                    )
                    messages[i]["content"] = content
                else:
                    messages[i][
                        "content"
                    ] = f"{content}\n[System instruction: {injection}]"
                break

        body["messages"] = messages
        return body

